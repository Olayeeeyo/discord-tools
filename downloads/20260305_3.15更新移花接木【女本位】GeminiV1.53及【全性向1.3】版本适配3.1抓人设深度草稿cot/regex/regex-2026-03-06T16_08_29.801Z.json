        "replaceString": "<div class=\"mf-a\"><div class=\"mf-a-flag\"><span class=\"mf-a-date\">$1</span><span class=\"mf-a-ed\">· Scene File ·</span><span class=\"mf-a-cast\">$2</span></div><div class=\"mf-a-hl\">$3</div><div class=\"mf-a-r1\"></div><div class=\"mf-a-r2\"></div><div class=\"mf-a-sub\">$4</div><div class=\"mf-a-cols\"><div class=\"mf-a-col\"><div class=\"mf-a-cl\">Location</div><div class=\"mf-a-cv\">$5</div></div><div class=\"mf-a-col\"><div class=\"mf-a-cl\">Weather</div><div class=\"mf-a-cv\">$6</div></div><div class=\"mf-a-col\"><div class=\"mf-a-cl\">Costume</div><div class=\"mf-a-cv\">$7</div></div></div></div><style>.mf-a{background:#f7f2e8;border-top:6px solid #1c1208;border-bottom:2px solid #1c1208;font-family:Georgia,serif}.mf-a-flag{border-bottom:3px double #1c1208;padding:6px 20px;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:12px;background:#f0ead8}.mf-a-date{font-family:'Courier New',monospace;font-size:9px;color:#5a4422}.mf-a-ed{font-size:9px;color:#8b6f3a;letter-spacing:3px;text-transform:uppercase;white-space:nowrap}.mf-a-cast{font-family:'Courier New',monospace;font-size:9px;color:#5a4422;text-align:right;font-style:italic}.mf-a-hl{font-size:24px;font-weight:700;color:#0f0a04;text-align:center;padding:10px 24px 4px;letter-spacing:.5px;line-height:1.1}.mf-a-r1{height:3px;background:#1c1208;margin:4px 20px 2px}.mf-a-r2{height:1px;background:#1c1208;margin:0 20px 0}.mf-a-sub{font-style:italic;font-size:12px;color:#4a3318;text-align:center;padding:5px 24px 8px;border-bottom:1px solid #1c1208}.mf-a-cols{display:grid;grid-template-columns:1fr 1fr 1fr}.mf-a-col{padding:8px 16px 10px;position:relative}.mf-a-col:not(:last-child)::after{content:'';position:absolute;top:8px;bottom:8px;right:0;width:1px;background:repeating-linear-gradient(to bottom,#a08060 0,#a08060 3px,transparent 3px,transparent 7px)}.mf-a-cl{font-family:'Courier New',monospace;font-size:7px;letter-spacing:2px;color:#8b6f3a;text-transform:uppercase;padding-bottom:3px;border-bottom:1px solid #c8b48a;margin-bottom:4px}.mf-a-cv{font-size:11px;color:#1c1208;line-height:1.6}</style>",
