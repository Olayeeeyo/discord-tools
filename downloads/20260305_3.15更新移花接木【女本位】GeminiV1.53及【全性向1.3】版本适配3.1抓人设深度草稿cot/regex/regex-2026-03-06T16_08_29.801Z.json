 Serif SC',serif;font-size:12px;font-style:italic;color:#999;margin-top:4px}.mf-c-grid{display:grid;grid-template-columns:1fr 1fr 1fr}.mf-c-cell{padding:9px 24px 11px;border-right:1px solid #ececec;display:flex;flex-direction:column;gap:4px}.mf-c-cl{font-family:'Courier New',monospace;font-size:7px;letter-spacing:2.5px;color:#ccc;text-transform:uppercase}.mf-c-cv{font-family:'Noto Serif SC',Georgia,serif;font-size:11px;color:#222;line-height:1.6}</style>",
