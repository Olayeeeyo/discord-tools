        "trimStrings": [],
        "replaceString": "<div class=\"mf-b\"><div class=\"mf-b-hd\"><span class=\"mf-b-dt\">$1</span><span class=\"mf-b-cast\">$2</span></div><div class=\"mf-b-body\"><div class=\"mf-b-title\">$3</div><div class=\"mf-b-deco\">✦ · · · ✦</div><div class=\"mf-b-quote\">$4</div></div><div class=\"mf-b-ft\"><div class=\"mf-b-cell\"><div class=\"mf-b-cl\">🗺 Location</div><div class=\"mf-b-cv\">$5</div></div><div class=\"mf-b-cell\"><div class=\"mf-b-cl\">🌤 Weather</div><div class=\"mf-b-cv\">$6</div></div><div class=\"mf-b-cell mf-b-last\"><div class=\"mf-b-cl\">👗 Costume</div><div class=\"mf-b-cv\">$7</div></div></div></div><style>@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap');.mf-b{font-family:'Nunito','Noto Serif SC',sans-serif;background:#fdfbf7;border-radius:24px;overflow:hidden;border:2.5px solid #e8e0d5;box-shadow:0 0 0 5px #fdfbf7,0 0 0 8px #ede5d8,0 8px 24px rgba(180,150,110,.1)}.mf-b-hd{background:linear-gradient(120deg,#f5efe6 0%,#ede5d8 50%,#f5efe6 100%);padding:10px 20px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px dashed #ddd0be;position:relative}.mf-b-hd::before{content:'◇';position:absolute;left:50%;transform:translateX(-50%);font-size:8px;color:#c8b898;bottom:-7px;background:#ede5d8;padding:0 6px}.mf-b-dt{font-family:'Courier New',monospace;font-size:9px;color:#a08060;letter-spacing:.5px}.mf-b-cast{font-size:11px;font-weight:700;color:#7a5c3a}.mf-b-body{padding:18px 24px 10px;text-align:center}.mf-b-title{font-size:22px;font-weight:700;color:#3a2e22;letter-spacing:3px;margin-bottom:8px;text-shadow:0 1px 0 rgba(255,255,255,.8)}.mf-b-deco{color:#c8b080;font-size:11px;letter-spacing:5px;margin-bottom:8px;opacity:.7}.mf-b-quote{font-size:12px;font-style:italic;color:#7a6550;line-height:1.75;padding-bottom:12px;position:relative}.mf-b-quote::after{content:'';display:block;width:40px;height:1.5px;background:linear-gradient(90deg,transparent,#d4c4a8,transparent);margin:10px auto 0}