    {
        "id": "ffccbf6b-46fb-4ee2-bc6b-c9523a950212",
        "scriptName": "【小说】白瓷极简摘要美化",
        "disabled": false,
        "runOnEdit": true,
        "findRegex": "<Godlog>[\\s\\S]*?<Nub>([\\s\\S]*?)<\\/Nub>[\\s\\S]*?<Title>([\\s\\S]*?)<\\/Title>[\\s\\S]*?<Time>([\\s\\S]*?)<\\/Time>[\\s\\S]*?<Pln>([\\s\\S]*?)<\\/Pln>[\\s\\S]*?<Per>([\\s\\S]*?)<\\/Per>[\\s\\S]*?<Cond>([\\s\\S]*?)<\\/Cond>[\\s\\S]*?<\\/Godlog>",
        "trimStrings": [],
        "replaceString": "<details class=\"ce-wave\"><summary class=\"ce-header\"><span class=\"ce-line ce-lineL\"></span><span class=\"ce-title\">$2</span><span class=\"ce-line ce-lineR\"></span><span class=\"ce-arrow\">+</span></summary><div class=\"ce-body\"><div class=\"ce-meta\"><div class=\"ce-row\"><span class=\"ce-tag\">$1</span><span class=\"ce-per\">$5</span></div><div class=\"ce-row\"><span class=\"ce-time\">$3</span><span class=\"ce-place\">$4</span></div></div><div class=\"ce-quote\">$6</div><div class=\"ce-deco\"><span class=\"ce-d1\"></span><span class=\"ce-d2\"></span><span class=\"ce-d3\"></span></div></div></details><style>.ce-wave{font-family:'Noto Serif SC',Georgia,serif;margin:20px 0;background:#fefefe;border-top:1px solid #222;border-bottom:1px solid #ddd;position:relative}.ce-header{list-style:none;cursor:pointer;padding:14px 18px;display:flex;align-items:center;gap:14px;position:relative;transition:background .25s}.ce-header::-webkit-details-marker{display:none}.ce-header:hover{background:rgba(0,0,0,.02)}.ce-line{height:1px;background:linear-gradient(90deg,transparent,#ccc);flex:1;transition:all .3s}.ce-lineR{background:linear-gradient(90deg,#ccc,transparent)}.ce-wave[open] .ce-line{background:linear-gradient(90deg,transparent,#999)}.ce-wave[open] .ce-lineR{background:linear-gradient(90deg,#999,transparent)}.ce-title{font-size:18px;font-weight:400;color:#111;letter-spacing:5px;white-space:nowrap;flex-shrink:0}.ce-arrow{position:absolute;right:16px;font-size:14px;color:#bbb;transition:transform .3s cubic-bezier(.34,1.56,.64,1);font-weight:300}.ce-wave[open] .ce-arrow{transform:rotate(45deg);color:#888}.ce-body{padding:18px 24px 22px;border-top:1px solid #f0f0f0;animation:ceIn .4s cubic-bezier(.22,1,.36,1)}@keyframes ceIn{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}.ce-meta{display:grid;grid-template-columns:1fr 1fr;gap:0;margin-bottom:16px}.ce-row{display:contents}.ce-tag{font-family:'Courier New',monospace;font-size:9px;letter-spacing:2px;color:#aaa;text-transform:uppercase;padding:4px 0;border-bottom:1px solid #f5f5f5}.ce-per{font-size:11px;color:#444;text-align:right;padding:4px 0;border-bottom:1px solid #f5f5f5}.ce-time{font-size:11px;color:#888;padding:4px 0}.ce-place{font-size:11px;color:#888;text-align:right;padding:4px 0}.ce-quote{font-size:15px;line-height:2;font-style:italic;text-align:center;color:#333;padding:20px 10px;margin:10px 0;position:relative}.ce-quote::before{content:'\\201C';font-family:Georgia,serif;font-size:48px;color:#f0f0f0;position:absolute;top:4px;left:8px;line-height:1;font-style:normal}.ce-quote::after{content:'\\201D';font-family:Georgia,serif;font-size:48px;color:#f0f0f0;position:absolute;bottom:-10px;right:8px;line-height:1;font-style:normal}.ce-deco{display:flex;justify-content:center;gap:6px;margin-top:14px}.ce-d1,.ce-d3{width:40px;height:1px;background:#e8e8e8}.ce-d2{width:6px;height:6px;border:1px solid #e0e0e0;transform:rotate(45deg)}</style>",
