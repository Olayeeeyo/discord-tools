        "id": "0dfdcafc-836d-4a90-9737-2a05ae9e82c0",
        "scriptName": "【小说】杂志剧情分支",
        "disabled": true,
        "runOnEdit": true,
        "findRegex": "<text>[\\s\\S]*?1\\.\\{\\{\\{\\{([\\s\\S]*?)\\}\\}\\}\\}[\\s\\S]*?2\\.\\{\\{\\{\\{([\\s\\S]*?)\\}\\}\\}\\}[\\s\\S]*?3\\.\\{\\{\\{\\{([\\s\\S]*?)\\}\\}\\}\\}[\\s\\S]*?4\\.\\{\\{\\{\\{([\\s\\S]*?)\\}\\}\\}\\}[\\s\\S]*?5\\.\\{\\{\\{\\{([\\s\\S]*?)\\}\\}\\}\\}[\\s\\S]*?<\\/text>",
        "trimStrings": [],
        "replaceString": "```\n<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Branch Selector</title>\n<style>\n* { box-sizing: border-box; margin: 0; padding: 0; }\nbody {\n  font-family: 'Georgia', 'Noto Serif SC', serif;\n  background: transparent;\n  padding: 12px;\n  font-size: 14px;\n}\n\n/* 整体容器 */\n.panel {\n  background: #fff;\n  border: 1px solid #e0e0e0;\n}\n\n/* 顶部masthead */\n.masthead {\n  padding: 8px 14px 7px;\n  border-bottom: 3px double #111;\n  display: flex;\n  align-items: baseline;\n  justify-content: space-between;\n}\n.masthead-title {\n  font-family: 'Courier New', monospace;\n  font-size: 7.5px;\n  letter-spacing: 4px;\n  text-transform: uppercase;\n  color: #888;\n}\n.masthead-rule {\n  flex: 1;\n  height: 1px;\n  background: #ddd;\n  margin: 0 12px;\n  position: relative;\n  top: -2px;\n}\n.masthead-count {\n  font-family: 'Courier New', monospace;\n  font-size: 7.5px;\n  color: #ccc;\n  letter-spacing: 1px;\n}\n\n/* 选项列表 */\n.option-list {\n  list-style: none;\n}\n\n.option-item {\n  display: grid;\n  grid-template-columns: 44px 1fr;\n  border-bottom: 1px solid #f0f0f0;\n  cursor: pointer;\n  transition: background .14s;\n  position: relative;\n}\n.option-item:last-child { border-bottom: none; }\n.option-item:hover { background: #fafafa; }\n.option-item.selected { background: #f5f5f5; }\n\n/* 大号编号 */\n.opt-num {\n  font-family: 'Georgia', serif;\n  font-size: 28px;\n  font-weight: 700;\n  color: #ebebeb;\n  line-height: 1;\n  padding: 10px 0 10px 14px;\n  display: flex;\n  align-items: center;\n  transition: color .14s;\n  user-select: none;\n  letter-spacing: -1px;\n}\n.option-item:hover .opt-num { color: #d8d8d8; }\n.option-item.selected .opt-num { color: #111; }\n\n/* 文字区 */\n.opt-body {\n  padding: 10px 14px 10px 8px;\n  display: flex;\n  flex-direction: column;\n  justify-content: center;\n  border-left: 1px solid #f0f0f0;\n  gap: 2px;\n}\n.opt-text {\n  font-size: 12.5px;\n  color: #444;\n  line-height: 1.5;\n  transition: color .14s;\n}\n.option-item:hover .opt-text { color: #111; }\n.option-item.selected .opt-text { color: #111; font-weight: 500; }\n\n.opt-tag {\n  font-family: 'Courier New', monospace;\n  font-size: 8px;\n  letter-spacing: 2px;\n  color: #ccc;\n  text-transform: uppercase;\n  transition: color .14s;\n}\n.option-item.selected .opt-tag { color: #999; }\n\n/* 选中时左侧黑条 */\n.option-item::before {\n  content: '';\n  position: absolute;\n  left: 0; top: 0; bottom: 0;\n  width: 0;\n  background: #111;\n  transition: width .16s cubic-bezier(.22,1,.36,1);\n}\n.option-item.selected::before { width: 3px; }\n\n/* 底部 display */\n.display {\n  padding: 9px 14px 10px;\n  border-top: 1px solid #e8e8e8;\n  background: #fafafa;\n  display: grid;\n  grid-template-columns: 8px 1fr;\n  gap: 10px;\n  align-items: start;\n  min-height: 18px;\n}\n.display-dot {\n  width: 6px; height: 6px;\n  border-radius: 50%;\n  border: 1.5px solid #ccc;\n  margin-top: 4px;\n  flex-shrink: 0;\n  transition: all .2s;\n}\n.display.active .display-dot {\n  background: #111;\n  border-color: #111;\n}\n.display-text {\n  font-family: 'Georgia', serif;\n  font-size: 11.5px;\n  color: #bbb;\n  font-style: italic;\n  line-height: 1.5;\n  transition: color .2s;\n}\n.display.active .display-text {\n  color: #333;\n  font-style: normal;\n}\n</style>\n</head>\n<body>\n<div class=\"panel\">\n  <div class=\"masthead\">\n    <span class=\"masthead-title\">Branch Selection</span>\n    <span class=\"masthead-rule\"></span>\n    <span class=\"masthead-count\">Vol.05</span>\n  </div>\n  <ul class=\"option-list\">\n    <li class=\"option-item\" onclick=\"pick(this,'$1')\">\n      <span class=\"opt-num\">01</span>\n      <div class=\"opt-body\"><span class=\"opt-tag\">Path A</span><span class=\"opt-text\">$1</span></div>\n    </li>\n    <li class=\"option-item\" onclick=\"pick(this,'$2')\">\n      <span class=\"opt-num\">02</span>\n      <div class=\"opt-body\"><span class=\"opt-tag\">Path B</span><span class=\"opt-text\">$2</span></div>\n    </li>\n    <li class=\"option-item\" onclick=\"pick(this,'$3')\">\n      <span class=\"opt-num\">03</span>\n      <div class=\"opt-body\"><span class=\"opt-tag\">Path C</span><span class=\"opt-text\">$3</span></div>\n    </li>\n    <li class=\"option-item\" onclick=\"pick(this,'$4')\">\n      <span class=\"opt-num\">04</span>\n      <div class=\"opt-body\"><span class=\"opt-tag\">Path D</span><span class=\"opt-text\">$4</span></div>\n    </li>\n    <li class=\"option-item\" onclick=\"pick(this,'$5')\">\n      <span class=\"opt-num\">05</span>\n      <div class=\"opt-body\"><span class=\"opt-tag\">Path E</span><span class=\"opt-text\">$5</span></div>\n    </li>\n  </ul>\n  <div class=\"display\" id=\"display\">\n    <span class=\"display-dot\"></span>\n    <span class=\"display-text\" id=\"display-text\">未选择</span>\n  </div>\n</div>\n<script>\nlet last = null;\nfunction pick(el, txt) {\n  last?.classList.remove('selected');\n  el.classList.add('selected');\n  last = el;\n  document.getElementById('display-text').innerText = txt;\n  document.getElementById('display').classList.add('active');\n  try {\n    const ta = window.parent.document.querySelector('#send_textarea');\n    if (!ta) return;\n    ta.value = txt;\n    ta.dispatchEvent(new Event('input', { bubbles: true }));\n  } catch(e) {}\n}\n</script>\n</body>\n</html>\n```",
