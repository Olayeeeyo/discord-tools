        "findRegex": "(?:<(think|thinking)>)?([\\s\\S]*?)<\\/(think|thinking)>",
        "replaceString": "<div class=\"suika-wrapper\">\n    <div class=\"suika-bg-layer\">\n        <video class=\"suika-video\" src=\"https://files.catbox.moe/gpdfqc.mp4\" autoplay loop muted playsinline></video>\n        <div class=\"suika-overlay\"></div>\n    </div>\n    <details class=\"suika-details\">\n        <summary class=\"suika-header\">\n            <span class=\"suika-icon\">♞</span>\n            <span class=\"suika-label\">TOUHOU</span>\n            <span class=\"suika-arrow\">▼</span>\n        </summary>\n        <div class=\"suika-content-box\">\n            <div class=\"suika-scroll-view\">\n                <div class=\"suika-text\">$2</div>\n            </div>\n        </div>\n    </details>\n</div>\n<style>\n    :root {\n        --suika-rind-dark: rgba(10, 40, 20, 0.85);\n        --suika-rind-light: #98ff98;\n        --suika-glass-blur: 8px;\n    }\n    .suika-wrapper {\n        position: relative;\n        width: 100%;\n        margin: 10px 0;\n        border: 1px solid rgba(152, 255, 152, 0.3);\n        border-radius: 12px;\n        overflow: hidden;\n        background: #051a05;\n        box-shadow: 0 4px 15px rgba(0, 20, 5, 0.6);\n        font-family: 'Segoe UI', 'Microsoft YaHei', sans-serif;\n        color: #fff;\n        contain-intrinsic-size: 300px;\n        transform: translate3d(0, 0, 0);\n        content-visibility: auto;\n        -webkit-mask-image: -webkit-radial-gradient(white, black);\n    }\n    .suika-bg-layer {\n        position: absolute;\n        top: 0; left: 0;\n        width: 100%; height: 100%;\n        z-index: 0;\n        pointer-events: none;\n        will-change: transform;\n    }\n    .suika-video {\n        width: 100%; height: 100%;\n        object-fit: cover;\n        opacity: 0.7;\n    }\n    .suika-overlay {\n        position: absolute; top: 0; left: 0; width: 100%; height: 100%;\n        background: linear-gradient(180deg, rgba(0, 50, 20, 0.4) 0%, rgba(0, 0, 0, 0.6) 100%);\n        mix-blend-mode: multiply;\n        z-index: 1;\n    }\n    .suika-details {\n        position: relative;\n        z-index: 10;\n        display: flex;\n        flex-direction: column;\n        height: 100%;\n    }\n    .suika-header {\n        display: flex;\n        align-items: center;\n        padding: 10px 15px;\n        cursor: pointer;\n        user-select: none;\n        background: rgba(10, 50, 25, 0.8);\n        border-bottom: 1px solid rgba(152, 255, 152, 0.15);\n    }\n    .suika-header:hover {\n        background: rgba(20, 70, 35, 0.7);\n    }\n    .suika-header::-webkit-details-marker, .suika-header::marker { display: none; }\n\n    .suika-icon {\n        margin-right: 10px;\n        font-size: 1.2em;\n        color: var(--suika-rind-light);\n        animation: suika-bounce 0.8s infinite alternate ease-in-out;\n        text-shadow: 0 0 8px rgba(152, 255, 152, 0.4);\n    }\n    @keyframes suika-bounce {\n        0% { transform: translateY(0) rotate(-5deg); }\n        100% { transform: translateY(-3px) rotate(5deg); }\n    }\n    .suika-label {\n        font-weight: 700;\n        font-size: 0.95em;\n        letter-spacing: 1px;\n        flex-grow: 1;\n        text-transform: uppercase;\n        color: #f0fff0;\n    }\n    .suika-arrow {\n        font-size: 0.8em;\n        opacity: 0.8;\n        transition: transform 0.2s ease;\n        color: var(--suika-rind-light);\n    }\n    .suika-details[open] .suika-arrow { transform: rotate(180deg); }\n\n    .suika-content-box {\n        position: relative;\n        background: var(--suika-rind-dark);\n        backdrop-filter: blur(var(--suika-glass-blur));\n        -webkit-backdrop-filter: blur(var(--suika-glass-blur));\n        will-change: opacity;\n    }\n    .suika-scroll-view {\n        min-height: 240px;\n        max-height: 240px;\n        overflow-y: auto;\n        padding: 15px 20px;\n        scrollbar-width: none;\n        -ms-overflow-style: none;\n    }\n    .suika-scroll-view::-webkit-scrollbar {\n        width: 0px;\n        background: transparent;\n    }\n    .suika-text {\n        font-size: 0.85em;\n        line-height: 1.5;\n        white-space: pre-wrap;\n        color: #ffffff;\n        text-shadow: 0 2px 4px rgba(0,0,0,0.8);\n    }\n    .suika-details[open] .suika-content-box {\n        animation: suika-fade 0.3s ease;\n    }\n    @keyframes suika-fade {\n        from { opacity: 0; }\n        to { opacity: 1; }\n    }\n</style>",
