        "id": "34ff7bf0-94a5-4151-a192-d541b1aaf14c",
        "scriptName": "美化摘要",
        "findRegex": "<summary>([\\s\\S]*?)<\\/summary>",
        "replaceString": "<div class=\"tenshi-rec-wrapper\">\n    <div class=\"tenshi-bg\" style=\"background-image: url('https://files.catbox.moe/08xjut.jpg');\"></div>\n    <div class=\"tenshi-overlay\"></div>\n    <div class=\"tenshi-content-box\">\n        <div class=\"tenshi-header\">\n            <span class=\"tenshi-tag\">SUMMARY</span>\n            <span class=\"tenshi-line\"></span>\n            <span class=\"tenshi-id\"></span>\n        </div>\n        <div class=\"tenshi-text\">$1</div>\n    </div>\n</div>\n<style>\n    .tenshi-rec-wrapper {\n        position: relative;\n        width: 100%;\n        min-height: 140px;\n        margin: 10px 0;\n        border-radius: 6px;\n        overflow: hidden;\n        background: #0d0d0d;\n        border: 1px solid #333;\n        box-shadow: 0 2px 5px rgba(0,0,0,0.5);\n        user-select: none;\n        content-visibility: auto;\n        transform: translate3d(0,0,0);\n        -webkit-mask-image: -webkit-radial-gradient(white, black);\n    }\n    .tenshi-bg {\n        position: absolute;\n        top: 0; left: 0;\n        width: 100%; height: 100%;\n        background-size: cover;\n        background-position: right top;\n        background-repeat: no-repeat;\n        filter: contrast(1.1) brightness(0.9);\n        z-index: 0;\n    }\n    .tenshi-overlay {\n        position: absolute;\n        top: 0; left: 0;\n        width: 100%; height: 100%;\n        z-index: 1;\n        background: linear-gradient(90deg,\n            rgba(17,17,17, 0.95) 0%,\n            rgba(17,17,17, 0.85) 55%,\n            rgba(17,17,17, 0.1) 100%\n        );\n    }\n    .tenshi-content-box {\n        position: relative;\n        z-index: 2;\n        padding: 15px;\n        width: 75%;\n        color: #ddd;\n        font-family: sans-serif;\n    }\n    .tenshi-header {\n        display: flex;\n        align-items: center;\n        margin-bottom: 8px;\n        opacity: 0.7;\n    }\n    .tenshi-tag {\n        font-size: 0.7em;\n        font-weight: bold;\n        background: #ddd;\n        color: #000;\n        padding: 1px 4px;\n        border-radius: 2px;\n        letter-spacing: 1px;\n    }\n    .tenshi-line {\n        flex-grow: 1;\n        height: 1px;\n        background: rgba(255,255,255,0.2);\n        margin: 0 8px;\n    }\n    .tenshi-id {\n        font-size: 0.6em;\n        font-family: 'Consolas', monospace;\n        letter-spacing: 1px;\n    }\n    .tenshi-text {\n        font-size: 0.85em;\n        line-height: 1.4;\n        text-shadow: 0 1px 2px #000;\n        font-style: italic;\n        border-left: 2px solid rgba(255,255,255,0.3);\n        padding-left: 10px;\n    }\n    .tenshi-text p { margin: 0; }\n</style>",
