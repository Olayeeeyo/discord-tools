le, rgba(0,0,0,0) 40%, rgba(0,0,0,0.9) 100%);\n        z-index: 2;\n    }\n    .ba-details {\n        position: relative;\n        z-index: 10;\n        display: flex;\n        flex-direction: column;\n    }\n    .ba-header {\n        display: flex;\n        align-items: center;\n        padding: 8px 12px;\n        cursor: pointer;\n        user-select: none;\n        background: rgba(0, 0, 0, 0.6);\n        backdrop-filter: blur(4px);\n        border-bottom: 1px solid rgba(255,255,255,0.1);\n        z-index: 20;\n    }\n    .ba-header::-webkit-details-marker, .ba-header::marker { display: none; }\n\n    .ba-icon {\n        margin-right: 8px;\n        font-size: 1.1em;\n        animation: ba-spin 6s linear infinite;\n        text-shadow: 0 0 8px rgba(255,255,255,0.6);\n    }\n    @keyframes ba-spin { 100% { transform: rotate(360deg); } }\n    .ba-label {\n        font-weight: 700;\n        font-size: 0.9em;\n        letter-spacing: 1px;\n        flex-grow: 1;\n        text-transform: uppercase;\n        opacity: 0.9;\n    }\n    .ba-arrow {\n        font-size: 0.8em;\n        opacity: 0.7;\n        transition: transform 0.2s ease;\n    }\n    .ba-details[open] .ba-arrow { transform: rotate(180deg); }\n    .ba-content {\n        min-height: 240px;\n        max-height: 240px;\n        overflow-y: auto;\n        overflow-x: hidden;\n        background: rgba(0, 0, 0, 0.3);\n        position: relative;\n    }\n    .ba-scroll::-webkit-scrollbar {\n        width: 0px;\n    }\n    .ba-scroll::-webkit-scrollbar-track {\n        background: rgba(0,0,0,0);\n    }\n    .ba-scroll::-webkit-scrollbar-thumb {\n        background: rgba(0,0,0,0);\n        border-radius: 0px;\n    }\n    .ba-text {\n        padding: 12px 16px 0px 16px; /* 上 右 下 左 */\n        font-size: 0.9em;\n        line-height: 1.5;\n        white-space: pre-wrap;\n        text-shadow: 1px 1px 0 #000;\n        padding-bottom: 20px;\n    }\n    .ba-details[open] .ba-content {\n        animation: ba-fade-in 0.3s ease;\n    }\n    @keyframes ba-fade-in { from { opacity: 0; } to { opacity: 1; } }\n</style>",
